// prisma/schema.prisma
// ─────────────────────────────────────────────────────────────────────────────
// CHANGES: 
//   1. Add ApprovalStatus enum
//   2. Add approval fields to Attendance model
//   3. Everything else UNCHANGED
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEAM_LEAD_DAY
  TEAM_LEAD_NIGHT
  STAFF
}

enum Team {
  DAY
  NIGHT
}

enum LeaveType {
  PAID
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

// ── NEW ───────────────────────────────────────────────────────────────────────
enum ApprovalStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  usernameLower String   @unique
  passwordHash  String
  role          Role     @default(STAFF)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile       StaffProfile?
  attendance    Attendance[]
  workLogs      HourlyWorkLog[]
  leaveRequests LeaveRequest[]  @relation("StaffLeaves")
  decidedLeaves LeaveRequest[]  @relation("DecidedLeaves")
  // ── NEW: attendance approvals given by this user
  approvedAttendance Attendance[] @relation("AttendanceApprover")
  auditLogs     AuditLog[]
  hourEntries   HourEntry[]

  @@index([usernameLower])
}

model StaffProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  photoUrl      String?
  team          Team     @default(DAY)
  monthlySalary Float    @default(10000)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Campaign {
  id        String   @id @default(cuid())
  name      String
  team      Team
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workLogs  HourlyWorkLog[]

  @@index([team])
}

model Attendance {
  id        String    @id @default(cuid())
  staffId   String
  staff     User      @relation(fields: [staffId], references: [id], onDelete: Cascade)
  date      DateTime  @db.Date
  checkIn   DateTime?
  checkOut  DateTime?

  // ── NEW: approval fields ──────────────────────────────────────────────────
  approvalStatus  ApprovalStatus @default(PENDING_APPROVAL)
  approvedById    String?
  approvedBy      User?          @relation("AttendanceApprover", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  approvedHours   Float?         // TL/Admin can override hours
  approvalNote    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([staffId, date])
  @@index([staffId, date])
  // ── NEW indexes ───────────────────────────────────────────────────────────
  @@index([approvalStatus])
  @@index([approvedById])
}

model HourlyWorkLog {
  id          String   @id @default(cuid())
  staffId     String
  staff       User     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  date        DateTime @db.Date
  hourIndex   Int
  formsCount  Int      @default(0)
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([staffId, date, hourIndex])
  @@index([staffId, date])
  @@index([campaignId, date])
}

model LeaveRequest {
  id          String      @id @default(cuid())
  staffId     String
  staff       User        @relation("StaffLeaves", fields: [staffId], references: [id], onDelete: Cascade)
  dateFrom    DateTime    @db.Date
  dateTo      DateTime    @db.Date
  type        LeaveType   @default(PAID)
  reason      String
  status      LeaveStatus @default(PENDING)
  decidedById String?
  decidedBy   User?       @relation("DecidedLeaves", fields: [decidedById], references: [id])
  decidedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([staffId])
  @@index([status])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation(fields: [actorId], references: [id])
  action     String
  entityType String
  entityId   String?
  beforeJson Json?
  afterJson  Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entityType])
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMPAIGN TRACKING MODELS
// ─────────────────────────────────────────────────────────────────────────────

model HourEntry {
  id        String         @id @default(cuid())
  staffId   String
  shiftKey  String
  hourStart DateTime
  hourEnd   DateTime
  campaigns CampaignWork[]
  staff     User           @relation(fields: [staffId], references: [id])
  createdAt DateTime       @default(now())

  @@index([staffId, shiftKey])
}

model CampaignWork {
  id            String    @id @default(cuid())
  hourEntryId   String
  name          String
  count         Int       @default(0)
  createdByRole String
  updatedAt     DateTime  @updatedAt
  hourEntry     HourEntry @relation(fields: [hourEntryId], references: [id], onDelete: Cascade)

  @@index([hourEntryId])
}
